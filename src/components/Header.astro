---
import HeaderMenu from "@data/global/header-menu.json";
const wordmark = "/images/components/header/wordmark-circle-rotated-transparency-173x173px.png";
const currentPath = Astro.url.pathname;
---

<header class="bg-blue">
	<div class="container flex-sm-row ">
	
			<a href="/" class="mb-4 mb-sm-0">
				<img src={wordmark} alt="Word mark: Letters PM inside a circle." width="173" height="173">
			</a>
			<ul>
				{
					HeaderMenu.map((menuItem) => (
						<li>
							<a href={menuItem.url} class={`${currentPath === menuItem.url ? "current-page" : ""}`}>{menuItem.text}</a>
						</li>
					))
				}
			</ul>
		</div>
	
</header>

<style lang="scss">
@import "../styles/base/_variables.scss";

	header {
		box-shadow: 0 1rem 2rem .1rem rgba(black, 0.1);
		margin-bottom: 6rem;
	}

	.container {
		padding-top: 2rem;
		padding-bottom: 2rem;
		justify-content: space-between;
		align-items: center;
	}

	img {
		width: 64px;
	}

	ul {
		list-style: none;
		margin: 0;
		padding-left: 0;
	}

	li {
		display: inline;
		margin-left: 0;
		font-size: 1.25rem;

		&:not(:first-of-type) {
			margin-left: 1.25rem;
		}
	}

	a {
		color: white;
		text-decoration: none;

		&:hover {
			color: white;
			text-decoration: underline;
		}
	}

	.current-page {
		font-weight: $fw-bold;
	}
</style>
